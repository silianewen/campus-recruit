# Local development env. Copy this file to .env.local and fill in values.
# .env.local is gitignored. NEVER commit real keys.

# Public Supabase config (Vite exposes VITE_* to the browser bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only — used by Edge Functions, never imported in frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# HR dashboard password. If unset, the app falls back to a demo password
# shown on the login screen — fine for local demos, NOT for production.
VITE_HR_PASSWORD=