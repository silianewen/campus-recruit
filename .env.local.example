# Local development env. Copy this file to .env.local and fill in values.
# .env.local is gitignored. NEVER commit real keys.

# Public Supabase config (Vite exposes VITE_* to the browser bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only — used by Edge Functions, never imported in frontend code.
# Frontend currently does NOT use this (all frontend queries use the anon key).
SUPABASE_SERVICE_ROLE_KEY=

# HR dashboard password.
# If unset, the HR login form on /dashboard and /stats is DISABLED — no fallback.
# Set this for both local dev (in .env.local) and prod (in Vercel project env).
VITE_HR_PASSWORD=